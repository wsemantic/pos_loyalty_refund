<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="wsem_gift_card.ReceiptHeaderCleanup" t-inherit="point_of_sale.ReceiptHeader" t-inherit-mode="extension">
        <!-- Remove tracking number container when present. -->
        <xpath expr="//span[hasclass('tracking-number')]/ancestor::div[1]" position="replace"/>

        <!--
            OCA l10n_es_pos_oca injects a second company address block after company name.
            Keep base address rendering and remove only this injected duplicate block.
        -->
        <xpath expr="//div[@t-if='props.data.company.street']" position="replace"/>
        <xpath expr="//div[@t-if='props.data.company.zip']" position="replace"/>
        <xpath expr="//div[@t-if='props.data.company.city']" position="replace"/>
        <xpath expr="//div[@t-if='props.data.company.state_id']" position="replace"/>

        <xpath expr="//div[@t-if='props.data.company.name']" position="after">
            <div t-if="props.data.company.street" t-esc="props.data.company.street"/>
            <div t-if="props.data.company.zip or props.data.company.city">
                <t t-if="props.data.company.zip" t-esc="props.data.company.zip"/>
                <t t-if="props.data.company.zip and props.data.company.city"> </t>
                <t t-if="props.data.company.city" t-esc="props.data.company.city"/>
            </div>
        </xpath>


        <!-- Show Spanish unique id in header instead of simplified invoice number. -->
        <xpath expr="//div[hasclass('simplified-invoice-number')]" position="replace">
            <div
                class="simplified-invoice-number"
                t-if="props.data.l10n_es_unique_id"
                t-esc="props.data.l10n_es_unique_id"
            />
        </xpath>

        <!-- Render order date in header right below simplified invoice number. -->
        <xpath expr="//div[hasclass('simplified-invoice-number')]" position="after">
             <div id="order-date" t-if="props.data.date" t-esc="props.data.date" />
        </xpath>
    </t>
</templates>
