<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="wsem_gift_card.ReceiptHeaderCleanup" t-inherit="point_of_sale.ReceiptHeader" t-inherit-mode="extension">
        <!-- Remove tracking number container when present. -->
        <xpath expr="//span[hasclass('tracking-number')]/ancestor::div[1]" position="replace"/>

        <!-- Remove empty placeholder node rendered as (). -->
        <xpath expr="//div[.='()']" position="replace"/>

        <!-- Render order date in header right below simplified invoice number. -->
        <xpath expr="//div[hasclass('simplified-invoice-number')]" position="after">
             <div id="order-date" t-esc="props.data.date" />			 
        </xpath>
    </t>
</templates>
