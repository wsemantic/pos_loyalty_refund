<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="wsem_gift_card.ReceiptHeaderCleanup" t-inherit="point_of_sale.ReceiptHeader" t-inherit-mode="extension">
        <!-- Remove tracking number container when present. -->
        <xpath expr="//span[hasclass('tracking-number')]/ancestor::div[1]" position="replace"/>

        <!-- Replace full contact block (including any previous OCA injections) and keep a custom header layout. -->
        <xpath expr="//div[hasclass('pos-receipt-contact')]" position="replace">
            <div class="pos-receipt-contact">
                <div class="simplified-invoice-number" t-if="props.data.l10n_es_unique_id">
                    <t>F. Simplif </t>
                    <t t-esc="props.data.l10n_es_unique_id"/>
                </div>
                <div id="order-date" t-if="props.data.date" t-esc="props.data.date" />
                <div t-if="props.data.company.name" t-esc="props.data.company.name"/>
                <div t-if="props.data.company.street" t-esc="props.data.company.street"/>
                <div t-if="props.data.company.zip or props.data.company.city">
                    <t t-if="props.data.company.zip" t-esc="props.data.company.zip"/>
                    <t t-if="props.data.company.zip and props.data.company.city"> </t>
                    <t t-if="props.data.company.city" t-esc="props.data.company.city"/>
                </div>
                <div t-if="props.data.company.vat" t-esc="props.data.company.vat"/>
                <div t-if="props.data.company.phone" t-esc="props.data.company.phone"/>
                <div t-if="props.data.company.website" t-esc="props.data.company.website"/>
                <t t-set="partner" t-value="props.data.partner"/>
                <t t-set="simplifiedPartnerId" t-value="Array.isArray(props.data.simplified_partner_id) ? props.data.simplified_partner_id[0] : (props.data.simplified_partner_id and props.data.simplified_partner_id.id) ? props.data.simplified_partner_id.id : props.data.simplified_partner_id"/>
                <t t-if="partner and partner.id != simplifiedPartnerId">
                    <div>Customer: <t t-esc="partner.name"/></div>
                    <div t-if="partner.vat">
                        <t t-esc="props.data.company.country?.vat_label || 'Tax ID'"/>:
                        <t t-esc="partner.vat"/>
                    </div>
                    <div t-if="partner.address" t-esc="partner.address"/>
                </t>
            </div>
        </xpath>

    </t>



    <t t-name="wsem_gift_card.ReceiptHeaderOcaNodeReplace" t-inherit="OrderReceipt" t-inherit-mode="extension">
        <!-- Explicitly replace OCA customer condition node so the original cannot render. -->
        <xpath expr="//div[hasclass('pos-receipt-contact')]/t[@t-if='partner and partner.id !== props.data.simplified_partner_id']" position="replace">
            <t t-set="simplifiedPartnerId" t-value="Array.isArray(props.data.simplified_partner_id) ? props.data.simplified_partner_id[0] : (props.data.simplified_partner_id and props.data.simplified_partner_id.id) ? props.data.simplified_partner_id.id : props.data.simplified_partner_id"/>
            <t t-if="partner and partner.id != simplifiedPartnerId">
                <div>Customer: <t t-esc="partner.name"/></div>
                <div t-if="partner.vat">
                    <t t-esc="props.data.company.country?.vat_label || 'Tax ID'"/>:
                    <t t-esc="partner.vat"/>
                </div>
                <div t-if="partner.address" t-esc="partner.address"/>
            </t>
        </xpath>
    </t>

</templates>
