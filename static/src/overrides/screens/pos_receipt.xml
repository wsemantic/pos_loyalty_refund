<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">
     <t t-name="wsem_gift_card.OrderReceipt" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//Orderline" position="inside">
                <t t-if="line.gift_card_code">
                    <div class="coupon-container">
                        <div style="max-width: 150px">
                            <img t-att-src="'/report/barcode/Code128/'+line.gift_card_code+'?width=800&amp;height=200&amp;quiet=0'" style="width:150px;height:25px" alt="Barcode"/>
                            <div style="text-align: center">
                                <t t-esc="line.gift_card_code"/>
                            </div>
                            <div style="text-align: center">
                                Saldo: <t t-esc="this.env.utils.formatCurrency(line.gift_card_balance)"/>
                            </div>
                        </div>
                    </div>
                </t>
        </xpath>

        <!-- Remove tracking number row from header. -->
        <xpath expr="//span[hasclass('tracking-number')]/.." position="replace"/>

        <!-- Remove branded and POS reference lines from footer metadata block. -->
        <xpath expr="//div[hasclass('pos-receipt-order-data')]/p[contains(translate(normalize-space(.), 'ABCDEFGHIJKLMNOPQRSTUVWXYZ횁횋횒횙횣', 'abcdefghijklmnopqrstuvwxyz찼챕챠처첬'), 'tecnolog챠a de odoo') or contains(translate(normalize-space(.), 'ABCDEFGHIJKLMNOPQRSTUVWXYZ', 'abcdefghijklmnopqrstuvwxyz'), 'technology of odoo')]" position="replace"/>
        <xpath expr="//div[hasclass('pos-receipt-order-data')]/div[starts-with(translate(normalize-space(.), 'ABCDEFGHIJKLMNOPQRSTUVWXYZ', 'abcdefghijklmnopqrstuvwxyz'), 'pedido') or starts-with(translate(normalize-space(.), 'ABCDEFGHIJKLMNOPQRSTUVWXYZ', 'abcdefghijklmnopqrstuvwxyz'), 'order')]" position="replace"/>

        <!-- Move the existing order date from footer metadata to header after simplified invoice number. -->
        <xpath expr="//div[hasclass('simplified-invoice-number')]" position="after">
            <xpath expr="//div[@id='order-date']" position="move"/>
        </xpath>

        <!-- Place barcode before footer block to ensure it is included before printer cut markers. -->
        <xpath expr="//div[hasclass('before-footer')]" position="before">
            <t t-set="simplifiedInvoiceNumber" t-value="(receipt and receipt.l10n_es_simplified_invoice_number) or (props and props.data and props.data.headerData and props.data.headerData.l10n_es_simplified_invoice_number) or (headerData and headerData.l10n_es_simplified_invoice_number)"/>
            <t t-if="simplifiedInvoiceNumber">
                <div class="pos-receipt-center-align wsem-simplified-invoice-barcode">
                    <img
                        t-att-src="'/report/barcode/Code128/' + simplifiedInvoiceNumber + '?width=560&amp;height=110&amp;quiet=0'"
                        alt="Simplified invoice barcode"
                    />
                    <div>
                        <t t-esc="simplifiedInvoiceNumber"/>
                    </div>
                </div>
            </t>
        </xpath>

        <!-- Extra bottom feed to avoid cutter reaching before the final receipt lines on some drivers. -->
        <xpath expr="//div[hasclass('pos-receipt-order-data')]" position="after">
            <div class="wsem-print-feed"/>
        </xpath>
    </t>

</templates>
