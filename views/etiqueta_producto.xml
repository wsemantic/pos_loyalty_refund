<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_simple_label_dymo_custom" inherit_id="product.report_simple_label_dymo" priority="99">
        <!--
            Apply style override from a stable container node instead of matching
            a specific inner price node that can change across inherited variants.
        -->
        <xpath expr="//*[@t-att-style='padding_page']" position="inside">
            <style>
                .o_label_price_small,
                .o_label_price_medium {
                    font-size: 1.7em !important;
                    margin-top: -5mm;
                    display: inline-block;
                }
            </style>
        </xpath>
    </template>
</odoo>
