<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_simple_label_dymo_custom" inherit_id="product.report_simple_label_dymo" priority="99">
        <!--
            Avoid contains() to prevent xpath quirks on processed templates.
            Match the original price node by exact class and keep a direct fallback.
        -->
        <xpath expr="//strong[@class='o_label_price_small'] | //div[@class='text-end']/strong" position="attributes">
            <attribute name="class">o_label_price_medium</attribute>
            <attribute name="style">font-size: 1.7em; margin-top: -5mm; display: inline-block;</attribute>
        </xpath>
    </template>
</odoo>
