<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_view_form_inherit_pos_loyalty_refund" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.pos_loyalty_refund</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='pos-loyalty']//div" position="after">
                <div class="content-group" invisible="not module_loyalty">
                    <div class="row mt16">
                        <label for="gift_card_product_id" class="col-lg-3 o_light_label"/>
                        <field name="gift_card_product_id" domain="[('sale_ok', '=', True), ('type', '=', 'service')]"/>
                    </div>
                </div>
            </xpath>
            <xpath expr="//setting[@id='pos-loyalty']" position="after">
                <setting/>
                <setting id="pos_receipt_width" string="Receipt Width" help="Receipt width">
                    <field name="receipt_width"/>
                </setting>
                <setting id="pos_second_print_with_price" string="Second Print With Price" help="Enable second print with price">
                    <field name="enable_second_print_with_price"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
